NODE_ENV=development
PORT=3001
# Matches `docker compose` postgres service (user pm, db pm_ai)
DATABASE_URL=postgresql://pm:pm@localhost:5432/pm_ai
JWT_SECRET=change-me
FRONTEND_URL=http://localhost:5173

REDIS_URL=
RATE_LIMIT_PER_MIN=100

S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3001/api/v1/integrations/jira/callback
JIRA_WEBHOOK_SECRET=
JIRA_ACCESS_TOKEN=
JIRA_CLOUD_ID=

FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=http://localhost:3001/api/v1/integrations/figma/callback
FIGMA_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=

SAML_ENTRY_POINT=
SAML_ISSUER=
SAML_CERT=
SAML_CALLBACK_URL=http://localhost:3001/api/v1/sso/saml/callback

SCIM_BEARER_TOKEN=

Y_LEVELDB_PATH=
