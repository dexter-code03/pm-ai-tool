# API
DATABASE_URL=postgresql://pm:pm@localhost:5432/pm_ai
JWT_SECRET=change-me-in-production
PORT=3001
FRONTEND_URL=http://localhost:5173

# Redis (rate limits / sessions — optional; falls back to in-memory)
REDIS_URL=redis://127.0.0.1:6379

# S3-compatible (MinIO local)
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=pm-ai-tool

# Jira OAuth (Phase 1)
JIRA_CLIENT_ID=
JIRA_REDIRECT_URI=http://localhost:3001/api/v1/integrations/jira/callback
JIRA_ACCESS_TOKEN=

# Figma (Phase 3)
FIGMA_CLIENT_ID=

# Google OAuth (Sign-in / Calendar — optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/google/callback

# OpenAI / AI
OPENAI_API_KEY=

# Request logging: set REQUEST_LOG=0 to disable one-line JSON logs; REQUEST_LOG_HEALTH=0 skips /health lines
# REQUEST_LOG=0
